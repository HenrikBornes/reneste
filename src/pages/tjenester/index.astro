---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CtaBanner from '../../components/CtaBanner.astro';
---

<Layout title="Tjenester – Reneste" description="Oversikt over Renestes tjenester: takvask, fasadevask, ventilasjonsrens og mer." activePage="tjenester">

  <PageHeader label="Hva vi tilbyr" heading="Våre tjenester" text="Vi tilbyr et komplett utvalg av utvendige rengjøringstjenester for din bolig." />

  <section class="services-overview">
    <div class="container">
      <div class="services-grid">
        <ServiceCard icon="🏠" title="Takvask" description="Fjerning av mose, alger og smuss fra alle typer tak. Skånsom høytrykk og biologisk behandling som forlenger takets levetid." href="/tjenester/takvask" />
        <ServiceCard icon="🧱" title="Fasadevask" description="Profesjonell vask av treverk, mur, betong og andre fasadematerialer. Gir boligen et friskt uttrykk og beskytter mot fukt." href="/tjenester/fasadevask" />
        <ServiceCard icon="💨" title="Ventilasjonsrens" description="Grundig rens av ventilasjonskanaler for bedre inneklima, lavere energiforbruk og redusert brannfare." href="/tjenester/ventilasjonsrens" />
        <ServiceCard icon="❄️" title="Varmepumperens" description="Profesjonell rengjøring av varmepumpe for optimal ytelse, bedre luftkvalitet og lengre levetid. Denne tjenesten lanseres snart." comingSoon={true} />
      </div>
    </div>
  </section>

  <CtaBanner heading="Usikker på hva du trenger?" text="Vi kommer gjerne på en gratis befaring og gir deg et uforpliktende tilbud." />

</Layout>
