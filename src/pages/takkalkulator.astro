---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Takkalkulator – Reneste" description="Beregn størrelsen på taket ditt automatisk. Søk opp adressen og få et prisestimat." activePage="tjenester">

  <PageHeader label="Verktøy" heading="Takkalkulator" text="Søk opp adressen din, så finner vi bygningen og beregner takflaten automatisk." />

  <section style="padding: 2rem 0 5rem;">
    <div class="container">

      <!-- Step 1: Address search -->
      <div class="calc-step" id="stepAddress">
        <div class="calc-card">
          <div class="step-badge">1</div>
          <h3>Søk opp adressen din</h3>
          <p class="step-desc">Begynn å skrive, så får du forslag fra hele Norge.</p>
          <div class="address-input-wrap">
            <input
              type="text"
              id="addressInput"
              placeholder="F.eks. Storgata 1, Oslo"
              autocomplete="off"
            />
            <div class="address-dropdown" id="addressDropdown"></div>
            <div class="input-spinner" id="searchSpinner" style="display:none;">
              <div class="spinner"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="calc-map-wrapper" id="mapWrapper" style="display:none;">
        <div id="map" class="calc-map"></div>
        <div class="calc-map-status" id="mapStatus">
          <div class="spinner"></div>
          <span>Henter bygningsdata...</span>
        </div>
      </div>

      <!-- Step 2: Building found -->
      <div class="calc-step" id="stepBuilding" style="display:none;">
        <div class="calc-card">
          <div class="step-badge">2</div>
          <h3>Vi fant bygningen din</h3>
          <p class="step-desc" id="buildingInfo">Grunnflaten er automatisk beregnet fra kartdata.</p>

          <div class="building-stats">
            <div class="building-stat">
              <span class="building-stat-label">Adresse</span>
              <span class="building-stat-value" id="selectedAddress">–</span>
            </div>
            <div class="building-stat">
              <span class="building-stat-label">Grunnflate (fotavtrykk)</span>
              <span class="building-stat-value" id="footprintArea">–</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: Pitch selection -->
      <div class="calc-step" id="stepPitch" style="display:none;">
        <div class="calc-card">
          <div class="step-badge">3</div>
          <h3>Velg takvinkel</h3>
          <p class="step-desc">Brattere tak = større takflate. De fleste norske boliger har 22–30°.</p>

          <div class="pitch-options" id="pitchOptions">
            <button class="pitch-btn" data-angle="0">
              <svg viewBox="0 0 60 32" class="pitch-svg"><line x1="5" y1="28" x2="55" y2="28" stroke="currentColor" stroke-width="2.5"/></svg>
              <span>Flatt<br><small>0°</small></span>
            </button>
            <button class="pitch-btn" data-angle="15">
              <svg viewBox="0 0 60 32" class="pitch-svg"><polyline points="5,28 30,18 55,28" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/></svg>
              <span>Slakt<br><small>15°</small></span>
            </button>
            <button class="pitch-btn selected" data-angle="25">
              <svg viewBox="0 0 60 32" class="pitch-svg"><polyline points="5,28 30,10 55,28" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/></svg>
              <span>Normal<br><small>25°</small></span>
            </button>
            <button class="pitch-btn" data-angle="35">
              <svg viewBox="0 0 60 32" class="pitch-svg"><polyline points="5,28 30,4 55,28" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/></svg>
              <span>Bratt<br><small>35°</small></span>
            </button>
            <button class="pitch-btn" data-angle="45">
              <svg viewBox="0 0 60 32" class="pitch-svg"><polyline points="10,28 30,2 50,28" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/></svg>
              <span>Veldig bratt<br><small>45°</small></span>
            </button>
          </div>
        </div>
      </div>

      <!-- Results -->
      <div class="calc-step" id="stepResults" style="display:none;">
        <div class="calc-results">
          <div class="calc-results-grid">
            <div class="calc-result-card">
              <span class="calc-result-label">Grunnflate</span>
              <span class="calc-result-value" id="resultFootprint">–</span>
            </div>
            <div class="calc-result-card accent">
              <span class="calc-result-label">Beregnet takflate</span>
              <span class="calc-result-value" id="resultRoof">–</span>
            </div>
            <div class="calc-result-card">
              <span class="calc-result-label">Estimert pris takvask</span>
              <span class="calc-result-value" id="resultPrice">–</span>
            </div>
          </div>

          <p class="results-note">Prisen er et estimat basert på takflate. Endelig pris avtales etter gratis befaring.</p>

          <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 1.5rem;">
            <a href="/tilbud" class="btn btn-primary btn-lg">Få tilbud basert på dette →</a>
            <button id="resetBtn" class="btn btn-secondary">Start på nytt</button>
          </div>
        </div>
      </div>

      <!-- Fallback: no building found -->
      <div class="calc-step" id="stepFallback" style="display:none;">
        <div class="calc-card">
          <div class="step-badge">!</div>
          <h3>Vi fant ikke bygningen automatisk</h3>
          <p class="step-desc">Oppgi mål manuelt, så beregner vi takflaten for deg.</p>
          <div class="manual-calc">
            <div class="form-group">
              <label for="manualLength">Lengde (meter)</label>
              <input type="number" id="manualLength" placeholder="F.eks. 12" min="1" step="0.5">
            </div>
            <div class="form-group">
              <label for="manualWidth">Bredde (meter)</label>
              <input type="number" id="manualWidth" placeholder="F.eks. 8" min="1" step="0.5">
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
  .calc-step {
    max-width: 700px;
    margin: 0 auto 1.5rem;
  }

  .calc-card {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--radius);
    padding: 2rem;
    position: relative;
  }

  .calc-card h3 {
    margin-bottom: 0.25rem;
  }

  .step-desc {
    font-size: 0.95rem;
    color: var(--mid-gray);
    margin-bottom: 1.5rem;
  }

  .step-badge {
    position: absolute;
    top: -12px;
    left: 24px;
    width: 28px;
    height: 28px;
    background: var(--accent);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
  }

  /* Address input */
  .address-input-wrap {
    position: relative;
  }

  .address-input-wrap input {
    width: 100%;
    padding: 1rem 1.25rem;
    padding-right: 3rem;
    border: 2px solid var(--light-gray);
    border-radius: var(--radius-sm);
    font-size: 1.1rem;
    font-family: inherit;
    transition: var(--transition);
  }

  .address-input-wrap input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 4px rgba(13, 158, 110, 0.1);
  }

  .input-spinner {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .spinner {
    width: 20px;
    height: 20px;
    border: 2.5px solid var(--light-gray);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Dropdown */
  .address-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-top: none;
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    box-shadow: var(--shadow-md);
    z-index: 100;
    display: none;
    max-height: 320px;
    overflow-y: auto;
  }

  .address-dropdown.open {
    display: block;
  }

  .address-option {
    padding: 0.85rem 1.25rem;
    cursor: pointer;
    transition: background 0.15s;
    border-bottom: 1px solid var(--off-white);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .address-option:last-child {
    border-bottom: none;
  }

  .address-option:hover {
    background: var(--accent-light);
  }

  .address-option .addr-main {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .address-option .addr-detail {
    font-size: 0.8rem;
    color: var(--mid-gray);
  }

  /* Map */
  .calc-map-wrapper {
    max-width: 700px;
    margin: 0 auto 1.5rem;
    border: 1px solid var(--light-gray);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .calc-map {
    width: 100%;
    height: 400px;
    background: var(--off-white);
  }

  .calc-map-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--off-white);
    border-top: 1px solid var(--light-gray);
    font-size: 0.85rem;
    color: var(--mid-gray);
  }

  .calc-map-status.success {
    color: var(--accent);
  }

  .calc-map-status.error {
    color: #e53e3e;
  }

  /* Building stats */
  .building-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .building-stat {
    background: var(--off-white);
    padding: 1rem;
    border-radius: var(--radius-sm);
  }

  .building-stat-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--mid-gray);
    margin-bottom: 0.25rem;
  }

  .building-stat-value {
    font-weight: 700;
    font-size: 1.05rem;
  }

  /* Pitch */
  .pitch-options {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .pitch-btn {
    flex: 1;
    min-width: 90px;
    padding: 0.75rem 0.5rem 0.6rem;
    border: 2px solid var(--light-gray);
    border-radius: var(--radius-sm);
    background: var(--white);
    cursor: pointer;
    text-align: center;
    transition: var(--transition);
    font-family: inherit;
    font-size: 0.85rem;
    color: var(--dark);
  }

  .pitch-btn:hover {
    border-color: var(--accent);
  }

  .pitch-btn.selected {
    border-color: var(--accent);
    background: var(--accent-light);
    color: var(--accent-dark);
  }

  .pitch-svg {
    width: 48px;
    height: 28px;
    margin: 0 auto 0.25rem;
    display: block;
  }

  .pitch-btn small {
    color: var(--mid-gray);
    font-weight: 600;
  }

  .pitch-btn.selected small {
    color: var(--accent);
  }

  /* Results */
  .calc-results {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--radius);
    padding: 2rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .calc-results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .calc-result-card {
    text-align: center;
    padding: 1.25rem 1rem;
    border-radius: var(--radius-sm);
    background: var(--off-white);
    border: 1px solid var(--light-gray);
  }

  .calc-result-card.accent {
    background: var(--accent-light);
    border-color: var(--accent);
  }

  .calc-result-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--mid-gray);
    margin-bottom: 0.35rem;
  }

  .calc-result-card.accent .calc-result-label {
    color: var(--accent-dark);
  }

  .calc-result-value {
    display: block;
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--dark);
  }

  .calc-result-card.accent .calc-result-value {
    color: var(--accent-dark);
  }

  .results-note {
    text-align: center;
    font-size: 0.85rem;
    color: var(--mid-gray);
  }

  /* Manual fallback */
  .manual-calc {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .manual-calc input {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid var(--light-gray);
    border-radius: var(--radius-sm);
    font-size: 1rem;
    font-family: inherit;
  }

  .manual-calc input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(13, 158, 110, 0.12);
  }

  @media (max-width: 768px) {
    .calc-results-grid {
      grid-template-columns: 1fr;
    }

    .pitch-options {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }

    .building-stats {
      grid-template-columns: 1fr;
    }

    .calc-map {
      height: 300px;
    }

    .manual-calc {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // ============================================
  // Takkalkulator – Kartverket + OpenStreetMap
  // Alt gratis, ingen API-nøkler
  // ============================================

  const PRICE_PER_SQM = 80;
  let map: any = null;
  let buildingLayer: any = null;
  let markerLayer: any = null;
  let currentPitchAngle = 25;
  let footprintSqm = 0;
  let selectedLat = 0;
  let selectedLon = 0;
  let debounceTimer: ReturnType<typeof setTimeout>;
  let L: any = null;

  // ----- Load Leaflet -----
  function loadLeaflet(): Promise<void> {
    return new Promise((resolve) => {
      if ((window as any).L) { L = (window as any).L; resolve(); return; }
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      s.onload = () => { L = (window as any).L; resolve(); };
      document.head.appendChild(s);
    });
  }

  // ----- Kartverket Address Search -----
  const addressInput = document.getElementById('addressInput') as HTMLInputElement;
  const dropdown = document.getElementById('addressDropdown')!;
  const spinner = document.getElementById('searchSpinner')!;

  addressInput?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    const q = addressInput.value.trim();
    if (q.length < 2) { dropdown.classList.remove('open'); return; }
    spinner.style.display = 'block';
    debounceTimer = setTimeout(() => searchKartverket(q), 250);
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.address-input-wrap')) {
      dropdown.classList.remove('open');
    }
  });

  async function searchKartverket(query: string) {
    try {
      const url = `https://ws.geonorge.no/adresser/v1/sok?sok=${encodeURIComponent(query)}&fuzzy=true&treffPerSide=8&asciiKompatibel=true`;
      const res = await fetch(url);
      const data = await res.json();
      spinner.style.display = 'none';

      if (!data.adresser || data.adresser.length === 0) {
        dropdown.innerHTML = '<div class="address-option"><span class="addr-main">Ingen treff</span></div>';
        dropdown.classList.add('open');
        return;
      }

      dropdown.innerHTML = data.adresser.map((addr: any) => {
        const main = addr.adressetekst || '';
        const post = `${addr.postnummer || ''} ${addr.poststed || ''}`;
        const kommune = addr.kommunenavn || '';
        const lat = addr.representasjonspunkt?.lat;
        const lon = addr.representasjonspunkt?.lon;
        return `
          <div class="address-option" data-lat="${lat}" data-lon="${lon}" data-address="${main}, ${post}">
            <span class="addr-main">${main}</span>
            <span class="addr-detail">${post} – ${kommune}</span>
          </div>
        `;
      }).join('');

      dropdown.classList.add('open');

      // Attach click handlers
      dropdown.querySelectorAll('.address-option').forEach(opt => {
        opt.addEventListener('click', () => {
          const el = opt as HTMLElement;
          const lat = parseFloat(el.dataset.lat || '0');
          const lon = parseFloat(el.dataset.lon || '0');
          const address = el.dataset.address || '';
          selectAddress(lat, lon, address);
        });
      });
    } catch {
      spinner.style.display = 'none';
    }
  }

  // ----- Address Selected -----
  async function selectAddress(lat: number, lon: number, address: string) {
    selectedLat = lat;
    selectedLon = lon;
    addressInput.value = address;
    dropdown.classList.remove('open');

    const addrEl = document.getElementById('selectedAddress');
    if (addrEl) addrEl.textContent = address;

    // Show map
    const mapWrapper = document.getElementById('mapWrapper')!;
    mapWrapper.style.display = 'block';

    const mapStatus = document.getElementById('mapStatus')!;
    mapStatus.innerHTML = '<div class="spinner"></div><span>Henter bygningsdata...</span>';
    mapStatus.className = 'calc-map-status';

    await loadLeaflet();
    initMap(lat, lon);
    await fetchBuilding(lat, lon);
  }

  // ----- Initialize Leaflet Map -----
  function initMap(lat: number, lon: number) {
    const mapEl = document.getElementById('map')!;

    if (map) {
      map.setView([lat, lon], 19);
    } else {
      map = L.map(mapEl, {
        zoomControl: true,
        attributionControl: true,
      }).setView([lat, lon], 19);

      // Satellite tiles (Esri – free)
      L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
        attribution: 'Tiles &copy; Esri',
        maxZoom: 20,
      }).addTo(map);
    }

    // Marker
    if (markerLayer) map.removeLayer(markerLayer);
    markerLayer = L.marker([lat, lon]).addTo(map);
  }

  // ----- Fetch Building Footprint from OSM -----
  async function fetchBuilding(lat: number, lon: number) {
    const mapStatus = document.getElementById('mapStatus')!;

    try {
      // Overpass API: find building at coordinate
      const radius = 25;
      const query = `
        [out:json][timeout:10];
        (
          way["building"](around:${radius},${lat},${lon});
          relation["building"](around:${radius},${lat},${lon});
        );
        out body;
        >;
        out skel qt;
      `;

      const res = await fetch('https://overpass-api.de/api/interpreter', {
        method: 'POST',
        body: `data=${encodeURIComponent(query)}`,
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      });

      const data = await res.json();

      // Build node lookup
      const nodes: Record<string, { lat: number; lon: number }> = {};
      data.elements.forEach((el: any) => {
        if (el.type === 'node') nodes[el.id] = { lat: el.lat, lon: el.lon };
      });

      // Find the closest building way
      const buildings = data.elements.filter((el: any) => el.type === 'way' && el.tags?.building);

      if (buildings.length === 0) {
        showFallback();
        mapStatus.innerHTML = '<span>Bygningen ble ikke funnet i kartdata. Bruk manuell kalkulator nedenfor.</span>';
        mapStatus.className = 'calc-map-status error';
        return;
      }

      // Pick closest building (by centroid distance)
      let bestBuilding = buildings[0];
      let bestDist = Infinity;

      buildings.forEach((b: any) => {
        const coords = b.nodes.map((nid: number) => nodes[nid]).filter(Boolean);
        if (coords.length === 0) return;
        const cLat = coords.reduce((s: number, c: any) => s + c.lat, 0) / coords.length;
        const cLon = coords.reduce((s: number, c: any) => s + c.lon, 0) / coords.length;
        const dist = Math.sqrt(Math.pow(cLat - lat, 2) + Math.pow(cLon - lon, 2));
        if (dist < bestDist) { bestDist = dist; bestBuilding = b; }
      });

      // Extract polygon coordinates
      const polyCoords = bestBuilding.nodes
        .map((nid: number) => nodes[nid])
        .filter(Boolean)
        .map((n: any) => [n.lat, n.lon]);

      if (polyCoords.length < 3) {
        showFallback();
        mapStatus.innerHTML = '<span>Kunne ikke lese bygningsform. Bruk manuell kalkulator.</span>';
        mapStatus.className = 'calc-map-status error';
        return;
      }

      // Draw on map
      if (buildingLayer) map.removeLayer(buildingLayer);
      buildingLayer = L.polygon(polyCoords, {
        color: '#0d9e6e',
        weight: 3,
        fillColor: '#0d9e6e',
        fillOpacity: 0.2,
      }).addTo(map);

      map.fitBounds(buildingLayer.getBounds().pad(0.3));

      // Calculate area (Shoelace formula with lat/lon → meters)
      footprintSqm = calculatePolygonArea(polyCoords);

      mapStatus.innerHTML = `<span>Bygning funnet – grunnflate: <strong>${footprintSqm.toFixed(0)} m²</strong></span>`;
      mapStatus.className = 'calc-map-status success';

      showBuildingResults();

    } catch {
      showFallback();
      mapStatus.innerHTML = '<span>Kunne ikke hente bygningsdata. Bruk manuell kalkulator.</span>';
      mapStatus.className = 'calc-map-status error';
    }
  }

  // ----- Calculate polygon area (m²) from lat/lon coords -----
  function calculatePolygonArea(coords: number[][]): number {
    // Convert to approximate meters using Mercator projection
    const toMeters = (lat: number, lon: number, refLat: number, refLon: number) => {
      const latRad = refLat * Math.PI / 180;
      const x = (lon - refLon) * Math.PI / 180 * 6371000 * Math.cos(latRad);
      const y = (lat - refLat) * Math.PI / 180 * 6371000;
      return { x, y };
    };

    const refLat = coords[0][0];
    const refLon = coords[0][1];
    const meters = coords.map(c => toMeters(c[0], c[1], refLat, refLon));

    // Shoelace formula
    let area = 0;
    for (let i = 0; i < meters.length; i++) {
      const j = (i + 1) % meters.length;
      area += meters[i].x * meters[j].y;
      area -= meters[j].x * meters[i].y;
    }
    return Math.abs(area) / 2;
  }

  // ----- Show building results -----
  function showBuildingResults() {
    document.getElementById('stepBuilding')!.style.display = 'block';
    document.getElementById('stepPitch')!.style.display = 'block';
    document.getElementById('stepResults')!.style.display = 'block';
    document.getElementById('stepFallback')!.style.display = 'none';

    document.getElementById('footprintArea')!.textContent = `${footprintSqm.toFixed(0)} m²`;

    updateResults();

    // Scroll to results
    document.getElementById('stepBuilding')!.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  // ----- Show fallback (manual) -----
  function showFallback() {
    document.getElementById('stepBuilding')!.style.display = 'none';
    document.getElementById('stepFallback')!.style.display = 'block';
    document.getElementById('stepPitch')!.style.display = 'block';
    document.getElementById('stepResults')!.style.display = 'block';

    const lInput = document.getElementById('manualLength') as HTMLInputElement;
    const wInput = document.getElementById('manualWidth') as HTMLInputElement;

    function calc() {
      const l = parseFloat(lInput?.value || '0');
      const w = parseFloat(wInput?.value || '0');
      if (l > 0 && w > 0) {
        footprintSqm = l * w;
        document.getElementById('footprintArea')!.textContent = `${footprintSqm.toFixed(0)} m²`;
        updateResults();
      }
    }

    lInput?.addEventListener('input', calc);
    wInput?.addEventListener('input', calc);
  }

  // ----- Update calculated results -----
  function updateResults() {
    if (footprintSqm <= 0) return;

    const pitchRad = (currentPitchAngle * Math.PI) / 180;
    const roofSqm = footprintSqm / Math.cos(pitchRad);

    const footprintEl = document.getElementById('resultFootprint');
    const roofEl = document.getElementById('resultRoof');
    const priceEl = document.getElementById('resultPrice');

    if (footprintEl) footprintEl.textContent = `${footprintSqm.toFixed(0)} m²`;
    if (roofEl) roofEl.textContent = `${roofSqm.toFixed(0)} m²`;

    const priceLow = Math.round(roofSqm * PRICE_PER_SQM * 0.8 / 100) * 100;
    const priceHigh = Math.round(roofSqm * PRICE_PER_SQM * 1.2 / 100) * 100;
    if (priceEl) priceEl.textContent = `${priceLow.toLocaleString('nb-NO')} – ${priceHigh.toLocaleString('nb-NO')} kr`;
  }

  // ----- Pitch buttons -----
  document.querySelectorAll('.pitch-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.pitch-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      currentPitchAngle = parseInt((btn as HTMLElement).dataset.angle || '25');
      updateResults();
    });
  });

  // ----- Reset -----
  document.getElementById('resetBtn')?.addEventListener('click', () => {
    addressInput.value = '';
    footprintSqm = 0;
    document.getElementById('mapWrapper')!.style.display = 'none';
    document.getElementById('stepBuilding')!.style.display = 'none';
    document.getElementById('stepPitch')!.style.display = 'none';
    document.getElementById('stepResults')!.style.display = 'none';
    document.getElementById('stepFallback')!.style.display = 'none';
    if (buildingLayer && map) { map.removeLayer(buildingLayer); buildingLayer = null; }
    if (markerLayer && map) { map.removeLayer(markerLayer); markerLayer = null; }
    addressInput.focus();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
