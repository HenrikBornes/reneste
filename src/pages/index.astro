---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import ServiceCard from '../components/ServiceCard.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import CtaBanner from '../components/CtaBanner.astro';
---

<Layout title="Reneste – Profesjonell utvendig rengjøring" activePage="hjem">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="section-label">Profesjonell utvendig rengjøring</p>
        <h1>Vi gjør taket ditt <span>som nytt</span></h1>
        <p>Reneste fjerner mose, alger og smuss fra tak og fasade – trygt, effektivt og med fornøydgaranti. Få et gratis og uforpliktende tilbud i dag.</p>
        <div class="hero-buttons">
          <a href="/tilbud" class="btn btn-primary btn-lg">Få tilbud →</a>
          <a href="/tak" class="btn btn-secondary btn-lg">Våre tjenester</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-image-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
          </svg>
          <span>Bilde: Rent tak etter vask</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Tjenester -->
  <section id="tjenester">
    <div class="container">
      <div style="text-align:center; margin-bottom:3rem;">
        <p class="section-label">Hva vi tilbyr</p>
        <h2>Våre tjenester</h2>
        <p style="margin:0.75rem auto 0;">Vi hjelper deg med å holde boligen din ren og velholdt – fra tak til grunn.</p>
      </div>
      <div class="services-grid">
        <ServiceCard icon="roof" title="Takvask" description="Fjerning av mose, alger og smuss. Skånsom behandling som forlenger takets levetid." href="/tak/takvask" />
        <ServiceCard icon="wall" title="Fasadevask" description="Profesjonell vask av alle typer fasader. Gir boligen et friskt og innbydende uttrykk." href="/fasade/fasadevask" />
        <ServiceCard icon="window" title="Vindusvask" description="Krystallklare vinduer og rene karmer – for mer lys og et penere uttrykk." href="/fasade/vindusvask" />
        <ServiceCard icon="wind" title="Ventilasjonsrens" description="Bedre inneklima og lavere energikostnader med rene ventilasjonskanaler." href="/rens/ventilasjonsrens" />
      </div>
    </div>
  </section>

  <!-- Før / Etter -->
  <section class="before-after-section" style="background: var(--off-white);">
    <div class="container">
      <div style="text-align:center; margin-bottom:3rem;">
        <p class="section-label">Resultater</p>
        <h2>Se forskjellen</h2>
        <p style="margin:0.75rem auto 0;">Dra slideren for å se før og etter. Resultatet taler for seg selv.</p>
      </div>
      <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; max-width: 900px; margin: 0 auto;">
        <div>
          <BeforeAfter beforeLabel="Før takvask" afterLabel="Etter takvask" />
          <p style="text-align:center; font-size:0.85rem; color:var(--mid-gray); margin-top:0.75rem;">Takvask – mose og alger fjernet</p>
        </div>
        <div>
          <BeforeAfter beforeLabel="Før fasadevask" afterLabel="Etter fasadevask" />
          <p style="text-align:center; font-size:0.85rem; color:var(--mid-gray); margin-top:0.75rem;">Fasadevask – grønnbelegg fjernet</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust -->
  <section class="trust">
    <div class="container">
      <div style="text-align:center; margin-bottom:3rem;">
        <p class="section-label">Hvorfor velge oss</p>
        <h2>Trygt og enkelt</h2>
      </div>
      <div class="trust-grid fade-in">
        <div class="trust-item">
          <div class="trust-icon"><Icon name="clipboard" size={28} /></div>
          <h3>Gratis befaring</h3>
          <p>Vi kommer hjem til deg og gir et uforpliktende tilbud – helt gratis.</p>
        </div>
        <div class="trust-item">
          <div class="trust-icon"><Icon name="check-circle" size={28} /></div>
          <h3>Fornøydgaranti</h3>
          <p>Er du ikke fornøyd, fikser vi det. Ingen spørsmål stilt.</p>
        </div>
        <div class="trust-item">
          <div class="trust-icon"><Icon name="shield" size={28} /></div>
          <h3>Trygge metoder</h3>
          <p>Vi bruker skånsomme og miljøvennlige metoder som tar vare på boligen din.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner heading="Klar for en renere bolig?" text="Få et gratis og uforpliktende tilbud i dag. Vi svarer innen 24 timer." />

</Layout>
