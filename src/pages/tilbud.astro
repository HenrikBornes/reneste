---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
---

<Layout title="Få tilbud – Reneste" description="Få et gratis og uforpliktende tilbud på takvask, fasadevask eller ventilasjonsrens fra Reneste.">

  <PageHeader label="Gratis & uforpliktende" heading="Få tilbud" text="Svar på noen enkle spørsmål og få et prisestimat med en gang." />

  <section class="quote-section">
    <div class="container">
      <div class="quote-calculator">

        <div class="quote-steps">
          <div class="quote-step active" data-step-num="1">
            <span class="step-num">1</span>
            <span>Adresse</span>
          </div>
          <div class="quote-step" data-step-num="2">
            <span class="step-num">2</span>
            <span>Bolig</span>
          </div>
          <div class="quote-step" data-step-num="3">
            <span class="step-num">3</span>
            <span>Tilbud</span>
          </div>
        </div>

        <div class="quote-body">

          <!-- Step 1 -->
          <div class="quote-panel active" data-step="1">
            <h3>Hvor bor du?</h3>
            <p>Oppgi adressen din slik at vi kan gi et mer presist estimat.</p>
            <div class="form-group">
              <label for="quoteAddress">Adresse</label>
              <div class="address-autocomplete">
                <input type="text" id="quoteAddress" placeholder="Begynn å skrive adressen din..." autocomplete="off">
                <div class="address-dropdown" id="quoteDropdown"></div>
              </div>
            </div>
            <div class="form-group">
              <label>Hvilken tjeneste er du interessert i?</label>
              <div class="option-grid">
                <div class="option-card selected" data-field="tjeneste" data-value="takvask">
                  <div class="option-icon"><Icon name="roof" size={28} /></div>Takvask
                </div>
                <div class="option-card" data-field="tjeneste" data-value="fasadevask">
                  <div class="option-icon"><Icon name="wall" size={28} /></div>Fasadevask
                </div>
                <div class="option-card" data-field="tjeneste" data-value="ventilasjonsrens">
                  <div class="option-icon"><Icon name="wind" size={28} /></div>Ventilasjon
                </div>
                <div class="option-card" data-field="tjeneste" data-value="flere">
                  <div class="option-icon"><Icon name="package" size={28} /></div>Flere tjenester
                </div>
              </div>
            </div>
            <div class="quote-nav">
              <div></div>
              <button class="btn btn-primary btn-next">Neste →</button>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="quote-panel" data-step="2">
            <h3>Fortell oss om boligen</h3>
            <p>Dette hjelper oss å gi et bedre estimat.</p>
            <div class="form-group">
              <label>Type bolig</label>
              <div class="option-grid">
                <div class="option-card" data-field="boligtype" data-value="enebolig">
                  <div class="option-icon"><Icon name="house" size={28} /></div>Enebolig
                </div>
                <div class="option-card" data-field="boligtype" data-value="rekkehus">
                  <div class="option-icon"><Icon name="townhouse" size={28} /></div>Rekkehus
                </div>
                <div class="option-card" data-field="boligtype" data-value="leilighet">
                  <div class="option-icon"><Icon name="apartment" size={28} /></div>Leilighet
                </div>
                <div class="option-card" data-field="boligtype" data-value="hytte">
                  <div class="option-icon"><Icon name="cabin" size={28} /></div>Hytte
                </div>
              </div>
            </div>
            <div class="form-group">
              <label>Taktype (valgfritt)</label>
              <div class="option-grid">
                <div class="option-card" data-field="taktype" data-value="betongstein">Betongstein</div>
                <div class="option-card" data-field="taktype" data-value="teglstein">Teglstein</div>
                <div class="option-card" data-field="taktype" data-value="salttak">Salttak</div>
                <div class="option-card" data-field="taktype" data-value="skifer">Skifer</div>
                <div class="option-card" data-field="taktype" data-value="annet">Annet / vet ikke</div>
              </div>
            </div>
            <div class="quote-nav">
              <button class="btn btn-secondary btn-back">← Tilbake</button>
              <button class="btn btn-primary btn-next">Se estimat →</button>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="quote-panel" data-step="3">
            <div class="quote-result">
              <p class="section-label">Ditt prisestimat</p>
              <div class="price-range">6 000 – 12 000 kr</div>
              <p class="price-note">Estimert pris basert på dine opplysninger. Endelig pris avtales etter befaring.</p>
              <div class="send-form">
                <h3 style="margin-bottom: 1rem;">Send forespørsel</h3>
                <form id="quoteForm" action="https://formspree.io/f/mlgorklk" method="POST">
                  <div class="form-group">
                    <label for="quoteName">Navn *</label>
                    <input type="text" id="quoteName" name="name" placeholder="Ditt fulle navn" required>
                  </div>
                  <div class="form-group">
                    <label for="quotePhone">Telefonnummer *</label>
                    <input type="tel" id="quotePhone" name="phone" placeholder="XXX XX XXX" required>
                  </div>
                  <div class="form-group">
                    <label for="quoteEmail">E-post</label>
                    <input type="email" id="quoteEmail" name="email" placeholder="din@epost.no">
                  </div>
                  <input type="hidden" name="adresse" id="quoteHiddenAddress">
                  <input type="hidden" name="tjeneste" id="quoteHiddenTjeneste">
                  <input type="hidden" name="boligtype" id="quoteHiddenBoligtype">
                  <input type="hidden" name="taktype" id="quoteHiddenTaktype">
                  <input type="hidden" name="prisestimat" id="quoteHiddenPris">
                  <input type="hidden" name="_subject" value="Ny tilbudsforespørsel fra reneste.no">
                  <button type="submit" class="btn btn-primary btn-lg" style="width:100%; justify-content:center;">Send forespørsel →</button>
                </form>
              </div>
            </div>
            <div class="quote-nav" style="margin-top: 1.5rem;">
              <button class="btn btn-secondary btn-back">← Tilbake</button>
              <div></div>
            </div>
          </div>

        </div>
      </div>

      <div style="display: flex; justify-content: center; gap: 2.5rem; margin-top: 2.5rem; flex-wrap: wrap; color: var(--mid-gray); font-size: 0.9rem;">
        <span style="display:inline-flex; align-items:center; gap:0.4rem;"><Icon name="clipboard" size={16} /> Gratis befaring</span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;"><Icon name="check-circle" size={16} /> Fornøydgaranti</span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;"><Icon name="lightning" size={16} /> Svar innen 24 timer</span>
      </div>
    </div>
  </section>

</Layout>

<style>
  .address-autocomplete {
    position: relative;
  }

  .address-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-top: none;
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    box-shadow: var(--shadow-md);
    z-index: 100;
    display: none;
    max-height: 280px;
    overflow-y: auto;
  }

  .address-dropdown.open {
    display: block;
  }

  .address-option {
    padding: 0.7rem 1rem;
    cursor: pointer;
    transition: background 0.15s;
    border-bottom: 1px solid var(--off-white);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .address-option:last-child { border-bottom: none; }
  .address-option:hover { background: var(--accent-light); }
  .address-option .addr-main { font-weight: 600; font-size: 0.9rem; }
  .address-option .addr-detail { font-size: 0.78rem; color: var(--mid-gray); }
</style>

<script>
  // --- Kartverket address autocomplete for tilbud ---
  {
    let debounceTimer: ReturnType<typeof setTimeout>;
    const addrInput = document.getElementById('quoteAddress') as HTMLInputElement;
    const addrDropdown = document.getElementById('quoteDropdown')!;

    addrInput?.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const q = addrInput.value.trim();
      if (q.length < 2) { addrDropdown.classList.remove('open'); return; }
      debounceTimer = setTimeout(() => fetchAddresses(q), 250);
    });

    document.addEventListener('click', (e) => {
      if (!(e.target as Element).closest('.address-autocomplete')) {
        addrDropdown.classList.remove('open');
      }
    });

    async function fetchAddresses(query: string) {
      try {
        const res = await fetch(`https://ws.geonorge.no/adresser/v1/sok?sok=${encodeURIComponent(query)}&fuzzy=true&treffPerSide=6&asciiKompatibel=true`);
        const data = await res.json();
        if (!data.adresser?.length) {
          addrDropdown.innerHTML = '<div class="address-option"><span class="addr-main">Ingen treff</span></div>';
          addrDropdown.classList.add('open');
          return;
        }
        addrDropdown.innerHTML = data.adresser.map((a: any) => `
          <div class="address-option" data-address="${a.adressetekst}, ${a.postnummer} ${a.poststed}">
            <span class="addr-main">${a.adressetekst}</span>
            <span class="addr-detail">${a.postnummer} ${a.poststed} – ${a.kommunenavn}</span>
          </div>
        `).join('');
        addrDropdown.classList.add('open');
        addrDropdown.querySelectorAll('.address-option').forEach(opt => {
          opt.addEventListener('click', () => {
            addrInput.value = (opt as HTMLElement).dataset.address || '';
            addrDropdown.classList.remove('open');
          });
        });
      } catch { /* ignore */ }
    }
  }

  const quoteCalc = document.querySelector('.quote-calculator');
  if (quoteCalc) {
    let currentStep = 1;
    const state = { address: '', boligtype: '', taktype: '', tjeneste: 'takvask' };

    const panels = quoteCalc.querySelectorAll('.quote-panel');
    const steps = quoteCalc.querySelectorAll('.quote-step');

    function showStep(step) {
      panels.forEach(p => p.classList.remove('active'));
      steps.forEach(s => s.classList.remove('active', 'completed'));
      const activePanel = quoteCalc.querySelector(`[data-step="${step}"]`);
      if (activePanel) activePanel.classList.add('active');
      steps.forEach(s => {
        const sNum = parseInt(s.dataset.stepNum);
        if (sNum === step) s.classList.add('active');
        if (sNum < step) s.classList.add('completed');
      });
      currentStep = step;
    }

    quoteCalc.querySelectorAll('.option-card').forEach(card => {
      card.addEventListener('click', () => {
        card.closest('.option-grid').querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        if (card.dataset.field && card.dataset.value) state[card.dataset.field] = card.dataset.value;
      });
    });

    quoteCalc.querySelectorAll('.btn-next').forEach(btn => {
      btn.addEventListener('click', () => {
        if (currentStep === 1) {
          const addr = quoteCalc.querySelector('#quoteAddress');
          if (!addr.value.trim()) { addr.focus(); addr.style.borderColor = '#e53e3e'; setTimeout(() => addr.style.borderColor = '', 2000); return; }
          state.address = addr.value.trim();
        }
        if (currentStep === 2 && !state.boligtype) return;
        if (currentStep < 3) showStep(currentStep + 1);
        if (currentStep === 3) calculateEstimate();
      });
    });

    quoteCalc.querySelectorAll('.btn-back').forEach(btn => {
      btn.addEventListener('click', () => { if (currentStep > 1) showStep(currentStep - 1); });
    });

    function calculateEstimate() {
      let low = 5000, high = 10000;
      if (state.boligtype === 'enebolig') { low = 6000; high = 12000; }
      else if (state.boligtype === 'rekkehus') { low = 4500; high = 9000; }
      else if (state.boligtype === 'leilighet') { low = 3000; high = 6000; }
      else if (state.boligtype === 'hytte') { low = 5000; high = 10000; }
      if (state.taktype === 'betongstein') { low += 1000; high += 2000; }
      else if (state.taktype === 'salttak') { low += 500; high += 1500; }
      else if (state.taktype === 'skifer') { low += 2000; high += 3000; }
      const el = quoteCalc.querySelector('.price-range');
      if (el) el.textContent = `${low.toLocaleString('nb-NO')} – ${high.toLocaleString('nb-NO')} kr`;
    }

    const quoteForm = document.getElementById('quoteForm') as HTMLFormElement;
    if (quoteForm) {
      quoteForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Fill hidden fields with calculator state
        const h = (id: string, val: string) => { const el = document.getElementById(id) as HTMLInputElement; if (el) el.value = val; };
        h('quoteHiddenAddress', state.address);
        h('quoteHiddenTjeneste', state.tjeneste);
        h('quoteHiddenBoligtype', state.boligtype);
        h('quoteHiddenTaktype', state.taktype);
        h('quoteHiddenPris', quoteCalc.querySelector('.price-range')?.textContent || '');

        const btn = quoteForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalText = btn.textContent;
        btn.textContent = 'Sender...';
        btn.disabled = true;

        try {
          const res = await fetch(quoteForm.action, {
            method: 'POST',
            body: new FormData(quoteForm),
            headers: { 'Accept': 'application/json' },
          });

          if (res.ok) {
            quoteForm.closest('.quote-result')!.innerHTML = '<div style="text-align:center; padding:2rem 0;"><h3 style="color:var(--accent); margin-bottom:0.5rem;">Takk for din forespørsel!</h3><p>Vi sender deg et tilbud innen 24 timer.</p></div>';
          } else {
            btn.textContent = originalText;
            btn.disabled = false;
            alert('Noe gikk galt. Prøv igjen eller ring oss direkte.');
          }
        } catch {
          btn.textContent = originalText;
          btn.disabled = false;
          alert('Noe gikk galt. Prøv igjen eller ring oss direkte.');
        }
      });
    }

    showStep(1);
  }
</script>
