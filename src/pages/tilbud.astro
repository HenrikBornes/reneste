---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Få tilbud – Reneste" description="Få et gratis og uforpliktende tilbud på takvask, fasadevask eller ventilasjonsrens fra Reneste.">

  <PageHeader label="Gratis & uforpliktende" heading="Få tilbud" text="Svar på noen enkle spørsmål og få et prisestimat med en gang." />

  <section class="quote-section">
    <div class="container">
      <div class="quote-calculator">

        <div class="quote-steps">
          <div class="quote-step active" data-step-num="1">
            <span class="step-num">1</span>
            <span>Adresse</span>
          </div>
          <div class="quote-step" data-step-num="2">
            <span class="step-num">2</span>
            <span>Bolig</span>
          </div>
          <div class="quote-step" data-step-num="3">
            <span class="step-num">3</span>
            <span>Tilbud</span>
          </div>
        </div>

        <div class="quote-body">

          <!-- Step 1 -->
          <div class="quote-panel active" data-step="1">
            <h3>Hvor bor du?</h3>
            <p>Oppgi adressen din slik at vi kan gi et mer presist estimat.</p>
            <div class="form-group">
              <label for="quoteAddress">Adresse</label>
              <input type="text" id="quoteAddress" placeholder="F.eks. Storgata 1, 0182 Oslo">
            </div>
            <div class="form-group">
              <label>Hvilken tjeneste er du interessert i?</label>
              <div class="option-grid">
                <div class="option-card selected" data-field="tjeneste" data-value="takvask">
                  <div class="option-icon">🏠</div>Takvask
                </div>
                <div class="option-card" data-field="tjeneste" data-value="fasadevask">
                  <div class="option-icon">🧱</div>Fasadevask
                </div>
                <div class="option-card" data-field="tjeneste" data-value="ventilasjonsrens">
                  <div class="option-icon">💨</div>Ventilasjon
                </div>
                <div class="option-card" data-field="tjeneste" data-value="flere">
                  <div class="option-icon">📦</div>Flere tjenester
                </div>
              </div>
            </div>
            <div class="quote-nav">
              <div></div>
              <button class="btn btn-primary btn-next">Neste →</button>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="quote-panel" data-step="2">
            <h3>Fortell oss om boligen</h3>
            <p>Dette hjelper oss å gi et bedre estimat.</p>
            <div class="form-group">
              <label>Type bolig</label>
              <div class="option-grid">
                <div class="option-card" data-field="boligtype" data-value="enebolig">
                  <div class="option-icon">🏡</div>Enebolig
                </div>
                <div class="option-card" data-field="boligtype" data-value="rekkehus">
                  <div class="option-icon">🏘️</div>Rekkehus
                </div>
                <div class="option-card" data-field="boligtype" data-value="leilighet">
                  <div class="option-icon">🏢</div>Leilighet
                </div>
                <div class="option-card" data-field="boligtype" data-value="hytte">
                  <div class="option-icon">🏔️</div>Hytte
                </div>
              </div>
            </div>
            <div class="form-group">
              <label>Taktype (valgfritt)</label>
              <div class="option-grid">
                <div class="option-card" data-field="taktype" data-value="betongstein">Betongstein</div>
                <div class="option-card" data-field="taktype" data-value="teglstein">Teglstein</div>
                <div class="option-card" data-field="taktype" data-value="skifer">Skifer</div>
                <div class="option-card" data-field="taktype" data-value="annet">Annet / vet ikke</div>
              </div>
            </div>
            <div class="quote-nav">
              <button class="btn btn-secondary btn-back">← Tilbake</button>
              <button class="btn btn-primary btn-next">Se estimat →</button>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="quote-panel" data-step="3">
            <div class="quote-result">
              <p class="section-label">Ditt prisestimat</p>
              <div class="price-range">6 000 – 12 000 kr</div>
              <p class="price-note">Estimert pris basert på dine opplysninger. Endelig pris avtales etter befaring.</p>
              <div class="send-form">
                <h3 style="margin-bottom: 1rem;">Send forespørsel</h3>
                <form id="quoteForm">
                  <div class="form-group">
                    <label for="quoteName">Navn *</label>
                    <input type="text" id="quoteName" name="name" placeholder="Ditt fulle navn" required>
                  </div>
                  <div class="form-group">
                    <label for="quotePhone">Telefonnummer *</label>
                    <input type="tel" id="quotePhone" name="phone" placeholder="XXX XX XXX" required>
                  </div>
                  <div class="form-group">
                    <label for="quoteEmail">E-post</label>
                    <input type="email" id="quoteEmail" name="email" placeholder="din@epost.no">
                  </div>
                  <button type="submit" class="btn btn-primary btn-lg" style="width:100%; justify-content:center;">Send forespørsel →</button>
                </form>
              </div>
            </div>
            <div class="quote-nav" style="margin-top: 1.5rem;">
              <button class="btn btn-secondary btn-back">← Tilbake</button>
              <div></div>
            </div>
          </div>

        </div>
      </div>

      <div style="display: flex; justify-content: center; gap: 2.5rem; margin-top: 2.5rem; flex-wrap: wrap; color: var(--mid-gray); font-size: 0.9rem;">
        <span>📋 Gratis befaring</span>
        <span>✅ Fornøydgaranti</span>
        <span>⚡ Svar innen 24 timer</span>
      </div>
    </div>
  </section>

</Layout>

<script>
  const quoteCalc = document.querySelector('.quote-calculator');
  if (quoteCalc) {
    let currentStep = 1;
    const state = { address: '', boligtype: '', taktype: '', tjeneste: 'takvask' };

    const panels = quoteCalc.querySelectorAll('.quote-panel');
    const steps = quoteCalc.querySelectorAll('.quote-step');

    function showStep(step) {
      panels.forEach(p => p.classList.remove('active'));
      steps.forEach(s => s.classList.remove('active', 'completed'));
      const activePanel = quoteCalc.querySelector(`[data-step="${step}"]`);
      if (activePanel) activePanel.classList.add('active');
      steps.forEach(s => {
        const sNum = parseInt(s.dataset.stepNum);
        if (sNum === step) s.classList.add('active');
        if (sNum < step) s.classList.add('completed');
      });
      currentStep = step;
    }

    quoteCalc.querySelectorAll('.option-card').forEach(card => {
      card.addEventListener('click', () => {
        card.closest('.option-grid').querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        if (card.dataset.field && card.dataset.value) state[card.dataset.field] = card.dataset.value;
      });
    });

    quoteCalc.querySelectorAll('.btn-next').forEach(btn => {
      btn.addEventListener('click', () => {
        if (currentStep === 1) {
          const addr = quoteCalc.querySelector('#quoteAddress');
          if (!addr.value.trim()) { addr.focus(); addr.style.borderColor = '#e53e3e'; setTimeout(() => addr.style.borderColor = '', 2000); return; }
          state.address = addr.value.trim();
        }
        if (currentStep === 2 && !state.boligtype) return;
        if (currentStep < 3) showStep(currentStep + 1);
        if (currentStep === 3) calculateEstimate();
      });
    });

    quoteCalc.querySelectorAll('.btn-back').forEach(btn => {
      btn.addEventListener('click', () => { if (currentStep > 1) showStep(currentStep - 1); });
    });

    function calculateEstimate() {
      let low = 5000, high = 10000;
      if (state.boligtype === 'enebolig') { low = 6000; high = 12000; }
      else if (state.boligtype === 'rekkehus') { low = 4500; high = 9000; }
      else if (state.boligtype === 'leilighet') { low = 3000; high = 6000; }
      else if (state.boligtype === 'hytte') { low = 5000; high = 10000; }
      if (state.taktype === 'betongstein') { low += 1000; high += 2000; }
      else if (state.taktype === 'skifer') { low += 2000; high += 3000; }
      const el = quoteCalc.querySelector('.price-range');
      if (el) el.textContent = `${low.toLocaleString('nb-NO')} – ${high.toLocaleString('nb-NO')} kr`;
    }

    const quoteForm = document.getElementById('quoteForm');
    if (quoteForm) {
      quoteForm.addEventListener('submit', (e) => {
        e.preventDefault();
        alert('Takk! Vi sender deg et tilbud innen 24 timer.');
        quoteForm.reset();
        showStep(1);
      });
    }

    showStep(1);
  }
</script>
