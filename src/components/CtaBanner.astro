---
interface Props {
  heading: string;
  text: string;
  linkText?: string;
  linkHref?: string;
}

const { heading, text, linkText = 'Få tilbud →', linkHref = '/tilbud' } = Astro.props;
---

<section class="cta-banner">
  <div class="container">
    <h2>{heading}</h2>
    <p>{text}</p>
    <a href={linkHref} class="btn btn-primary btn-lg">{linkText}</a>
  </div>
</section>
