---
import Icon from './Icon.astro';

interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
  comingSoon?: boolean;
}

const { icon, title, description, href, comingSoon = false } = Astro.props;
---

{href ? (
  <a href={href} class:list={['service-card', 'fade-in', { 'coming-soon': comingSoon }]}>
    {comingSoon && <span class="badge">Kommer snart</span>}
    <div class="icon"><Icon name={icon} size={28} /></div>
    <h3>{title}</h3>
    <p>{description}</p>
    <span class="card-link">Les mer →</span>
  </a>
) : (
  <div class:list={['service-card', 'fade-in', { 'coming-soon': comingSoon }]}>
    {comingSoon && <span class="badge">Kommer snart</span>}
    <div class="icon"><Icon name={icon} size={28} /></div>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
)}
